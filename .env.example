# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration (Frontend)
# Get this from Stripe Dashboard > Developers > API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ============================================================================
# Supabase Edge Function Environment Variables (set in Supabase Dashboard)
# ============================================================================
# STRIPE_SECRET_KEY=sk_test_your-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# STRIPE_PRICE_ID=price_your-price-id
# APP_URL=https://your-app-url.netlify.app
